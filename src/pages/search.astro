---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<BaseLayout
  title="Search"
  description="Search every article on Electrician Times — guides on electrical work, wiring, tools, devices and safety."
  canonical="/search/"
  noindex={true}
>
  <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'Search' }]} />
  <div class="container page-body">
    <h1>Search</h1>
    <p>Search every article on Electrician Times.</p>
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
    <div id="search" style="margin-top:1rem"></div>
    <noscript><p>Search requires JavaScript. You can also browse the <a href="/sitemap/">sitemap</a>.</p></noscript>
    <script is:inline src="/pagefind/pagefind-ui.js"></script>
    <script is:inline>
      window.addEventListener('DOMContentLoaded', function () {
        if (typeof PagefindUI === 'undefined') {
          document.getElementById('search').innerHTML =
            '<p>Search index not built yet. Run <code>npm run build</code> first.</p>';
          return;
        }
        var ui = new PagefindUI({ element: '#search', showSubResults: true, showImages: false });
        var q = new URLSearchParams(location.search).get('q');
        if (q) ui.triggerSearch(q);
      });
    </script>
  </div>
</BaseLayout>
