---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FaqSection from '../components/FaqSection.astro';
import { getPublishedPosts, categories } from '../utils/content';

const posts = await getPublishedPosts();
const totalPosts = posts.length;
const totalCategories = categories.length;

const EMAIL = 'admin@electriciantimes.com';
const WHATSAPP = '+44 7365 733099';
const WHATSAPP_LINK = 'https://wa.me/447365733099';

const mailtoGuest = `mailto:${EMAIL}?subject=${encodeURIComponent('Guest Post Pitch — Electrician Times')}&body=${encodeURIComponent('Hi Electrician Times team,\n\nProposed topic/title:\nBrief outline (3–5 bullets):\nAuthor / company:\nSample of previous work (links):\n\nThanks!')}`;

const faq = [
  {
    question: 'How long does publication take?',
    answer:
      'Once an article passes editorial review, publication is typically within 1–3 business days. If you have a deadline, mention it in your email and we will do our best to accommodate it.',
  },
  {
    question: 'Will my article stay online permanently?',
    answer:
      'Yes — published articles remain live for the lifetime of the site and are included in our sitemap, RSS feed and internal search, as long as they continue to meet our content standards.',
  },
  {
    question: 'Can businesses and agencies contribute?',
    answer:
      'Yes. Many of our contributors write on behalf of companies serving the electrical trade. Email admin@electriciantimes.com with what you have in mind and we will reply with the details — serious inquiries receive a same-day response.',
  },
  {
    question: 'What topics are off-limits?',
    answer:
      'Anything unrelated to the electrical trade or clearly adjacent industries — plus casino, adult, crypto speculation, pharmaceuticals and thin AI-generated filler. We recently removed nearly 100 off-topic posts to keep this site strictly electrical, and we protect that standard.',
  },
  {
    question: 'Do you edit submissions?',
    answer:
      'We may edit for clarity, formatting and safety. Significant changes are agreed with you before publication.',
  },
];
---

<BaseLayout
  title="Write for Us - Electrician Times"
  rawTitle={true}
  description="Contribute to Electrician Times — a 100% electrical-niche publication read by electricians, contractors and homeowners. See our guest post guidelines and pitch your article."
  canonical="/write-for-us/"
>
  <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'Write for Us' }]} />

  <div class="hero" style="padding:2.5rem 0">
    <div class="container">
      <span class="kicker">Guest Posts · Contributor Guidelines</span>
      <h1 style="color:#fff;margin:0 0 .6rem">Write for Electrician Times</h1>
      <p style="color:#c3d4e2;max-width:44rem;margin:0 0 1.4rem">
        Share your expertise with electricians, contractors, technicians and hands-on
        homeowners — on a publication that covers the electrical trade and nothing else.
      </p>
      <div class="hero-actions">
        <a class="button" href={mailtoGuest}>Pitch an Article</a>
        <a class="button ghost" href={`mailto:${EMAIL}`}>Email the Editor</a>
      </div>
      <div class="hero-stats">
        <div class="stat"><b>{totalPosts}+</b><span>Live articles</span></div>
        <div class="stat"><b>{totalCategories}</b><span>Electrical categories</span></div>
        <div class="stat"><b>100%</b><span>Electrical niche</span></div>
      </div>
    </div>
  </div>

  <div class="container page-body">
    <h2>Why write for Electrician Times</h2>
    <ul>
      <li><strong>A strictly electrical audience.</strong> Every category on this site — wiring, cables, protective devices, lighting, meters, tools, electrician business — serves one niche. Your article sits next to relevant content, not random filler.</li>
      <li><strong>Real editorial standards.</strong> We recently audited the entire site and removed ~100 off-topic posts. What remains (and what we publish) is electrical content only — which makes every byline here worth more.</li>
      <li><strong>Clean, fast, modern platform.</strong> Fully static, mobile-first and technically optimized: structured data on every article, XML sitemap, RSS, and internal links from related articles.</li>
      <li><strong>Permanent publication.</strong> Accepted articles stay live, indexed and internally linked for the life of the site.</li>
      <li><strong>Fast, human process.</strong> One email, a real editor, same-day answers on serious pitches, publication typically within 1–3 business days of approval.</li>
    </ul>

    <h2>What we publish</h2>
    <ul>
      <li>Practical guides: wiring, installations, troubleshooting, tools, safety</li>
      <li>Industry insight: standards, technology trends, smart homes, solar, EV charging</li>
      <li>Business content for electricians: marketing, operations, careers, licensing</li>
      <li>Stories and know-how from companies serving the electrical trade</li>
      <li>Adjacent trades where the angle is genuinely electrical (HVAC, construction, security systems)</li>
    </ul>

    <h2>Content requirements</h2>
    <ul>
      <li><strong>Original</strong> — never published elsewhere, and it must pass our review for accuracy</li>
      <li><strong>Substantial</strong> — 800+ words preferred; long-form welcome</li>
      <li><strong>Safe</strong> — no advice that encourages untrained readers to do hazardous electrical work; jurisdiction-specific claims must be accurate</li>
      <li><strong>Readable</strong> — clear headings, short paragraphs, proofread</li>
    </ul>

    <div class="callout info">
      <p><strong>Ready to pitch?</strong> Email
        <a href={`mailto:${EMAIL}`}>{EMAIL}</a> or WhatsApp
        <a href={WHATSAPP_LINK} rel="noopener noreferrer">{WHATSAPP}</a> with your topic or a
        short outline. Serious pitches get a same-day reply.
      </p>
      <p style="margin-top:0.8rem">
        <a class="button" href={mailtoGuest}>Pitch an Article&nbsp;→</a>
      </p>
    </div>

    <h2>How it works</h2>
    <ol>
      <li><strong>Pitch.</strong> Email your topic and a brief outline (or the finished draft).</li>
      <li><strong>Review.</strong> We confirm fit, agree the details and give you a publication date.</li>
      <li><strong>Publish.</strong> Your article goes live — indexed, internally linked and permanent.</li>
    </ol>

    <FaqSection faq={faq} title="Guest posting FAQ" />
  </div>
</BaseLayout>
