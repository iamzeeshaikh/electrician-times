---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import { getPublishedPosts, categories, categoryName, postUrl } from '../utils/content';

const posts = await getPublishedPosts();
const pages = await getCollection('pages');
const usedCategories = categories.filter((c) => c.postCount > 0).sort((a, b) => a.name.localeCompare(b.name));

// group posts by primary category for a scannable human sitemap
const byCat = new Map<string, typeof posts>();
for (const p of posts) {
  const c = p.data.primaryCategory || p.data.categories[0] || 'blog';
  if (!byCat.has(c)) byCat.set(c, [] as unknown as typeof posts);
  (byCat.get(c) as any).push(p);
}
const groups = [...byCat.entries()].sort((a, b) => b[1].length - a[1].length);
---

<BaseLayout
  title="Sitemap"
  description="Browse every article, category and page on Electrician Times from one place."
  canonical="/sitemap/"
>
  <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'Sitemap' }]} />
  <div class="container">
    <h1>Sitemap</h1>
    <p>
      Every page on Electrician Times. Looking for the XML sitemap? It's at
      <a href="/sitemap.xml">/sitemap.xml</a>.
    </p>

    <h2>Pages</h2>
    <ul>
      <li><a href="/">Home</a></li>
      {pages.map((p) => (
        <li><a href={`/${p.data.slug}/`}>{p.data.title}</a></li>
      ))}
      <li><a href="/write-for-us/">Write for Us</a></li>
      <li><a href="/editorial-policy/">Editorial Policy</a></li>
      <li><a href="/disclaimer/">Disclaimer</a></li>
      <li><a href="/search/">Search</a></li>
    </ul>

    <h2>Categories</h2>
    <ul>
      {usedCategories.map((c) => (
        <li>
          <a href={`/category/${c.slug}/`}>{c.name}</a> ({c.postCount})
        </li>
      ))}
    </ul>

    <h2>All Articles ({posts.length})</h2>
    {groups.map(([cat, list]) => (
      <section>
        <h3>{categoryName(cat)}</h3>
        <ul>
          {list.map((p) => (
            <li><a href={postUrl(p)}>{p.data.title}</a></li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</BaseLayout>
