---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import NewsletterBox from '../components/NewsletterBox.astro';
import JsonLd from '../components/JsonLd.astro';
import { getPublishedPosts, categories, categoryDescription } from '../utils/content';
import { SITE_NAME, SITE_URL, SITE_TAGLINE, SITE_DESCRIPTION, SITE_LOGO, absoluteUrl } from '../utils/site';

const posts = await getPublishedPosts();
const featured = posts.find((p) => p.data.featuredImage) ?? posts[0];
const latest = posts.filter((p) => p !== featured).slice(0, 9);
const featuredCat = featured.data.primaryCategory || featured.data.categories[0];
const totalPosts = posts.length;
const totalCategories = categories.filter((c) => c.postCount > 0).length;

const FEATURED_SECTIONS = [
  { slug: 'electrical', title: 'Electrical Fundamentals' },
  { slug: 'electricial-safety', title: 'Electrical Safety' },
  { slug: 'installing', title: 'Wiring & Installation' },
  { slug: 'device', title: 'Devices & Equipment' },
];

const sections = FEATURED_SECTIONS.map((s) => ({
  ...s,
  posts: posts.filter((p) => p.data.categories.includes(s.slug)).slice(0, 3),
})).filter((s) => s.posts.length > 0);

const topCategories = [...categories]
  .filter((c) => c.postCount >= 3 && c.slug !== 'uncategorized' && c.slug !== 'blog')
  .sort((a, b) => b.postCount - a.postCount)
  .slice(0, 8);

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE_NAME,
    url: `${SITE_URL}/`,
    description: SITE_DESCRIPTION,
    potentialAction: {
      '@type': 'SearchAction',
      target: { '@type': 'EntryPoint', urlTemplate: `${SITE_URL}/search/?q={search_term_string}` },
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: SITE_NAME,
    url: `${SITE_URL}/`,
    logo: absoluteUrl(SITE_LOGO),
  },
];
---

<BaseLayout
  title={`${SITE_NAME} - ${SITE_TAGLINE}`}
  rawTitle={true}
  description={SITE_DESCRIPTION}
  canonical="/"
>
  <div class="hero">
    <div class="container hero-inner">
      <div>
        <span class="kicker">The Electrical Trade, Explained</span>
        <h1>Practical Guides for Electricians &amp; Homeowners</h1>
        <p>
          Wiring, cables, sockets, protective devices, tools and safety — clear, technical
          articles written for electricians, technicians, students and hands-on homeowners.
        </p>
        <div class="hero-actions">
          <a class="button" href="/category/electricial-safety/">Electrical Safety Guides</a>
          <a class="button ghost" href="/sitemap/">Browse All Articles</a>
        </div>
        <div class="hero-stats">
          <div class="stat"><b>{totalPosts}+</b><span>In-depth articles</span></div>
          <div class="stat"><b>{totalCategories}</b><span>Topic categories</span></div>
          <div class="stat"><b>Safety-first</b><span>Editorial policy</span></div>
        </div>
      </div>
      <a class="hero-card" href={`/${featured.data.slug}/`}>
        <span class="hero-card-label">Latest</span>
        <img
          src={featured.data.featuredImage}
          alt=""
          width={featured.data.featuredImageWidth || 740}
          height={featured.data.featuredImageHeight || 462}
          fetchpriority="high"
          decoding="async"
        />
        <span class="hero-card-body">
          {featuredCat && <span class="cat-pill">{categories.find((c) => c.slug === featuredCat)?.name ?? featuredCat}</span>}
          <h2>{featured.data.title}</h2>
        </span>
      </a>
    </div>
  </div>

  <div class="container">
    <div class="section-head">
      <h2>Latest Articles</h2>
      <a class="more" href="/category/blog/">All articles →</a>
    </div>
    <ul class="card-grid">
      {latest.map((p, i) => (
        <li style="list-style:none">
          <ArticleCard post={p} eager={i < 3} />
        </li>
      ))}
    </ul>

    <div class="section-head">
      <h2>Browse by Topic</h2>
    </div>
    <ul class="card-grid">
      {topCategories.map((c) => (
        <li style="list-style:none">
          <a class="category-card" href={`/category/${c.slug}/`}>
            <h3>{c.name}</h3>
            <p>{categoryDescription(c.slug)}</p>
            <span class="count">{c.postCount} article{c.postCount === 1 ? '' : 's'}</span>
          </a>
        </li>
      ))}
    </ul>

    {sections.map((s) => (
      <section>
        <div class="section-head">
          <h2>{s.title}</h2>
          <a class="more" href={`/category/${s.slug}/`}>More →</a>
        </div>
        <ul class="card-grid">
          {s.posts.map((p) => (
            <li style="list-style:none">
              <ArticleCard post={p} showExcerpt={false} />
            </li>
          ))}
        </ul>
      </section>
    ))}

    <NewsletterBox />
  </div>
  <JsonLd data={schema} />
</BaseLayout>
