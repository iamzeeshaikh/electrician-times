---
import type { BlogPost } from '../utils/content';
import ArticleCard from './ArticleCard.astro';

export interface Props {
  posts: BlogPost[];
  title?: string;
}
const { posts, title = 'Related Articles' } = Astro.props;
---

{posts.length > 0 && (
  <section class="container" aria-label={title}>
    <div class="section-head">
      <h2>{title}</h2>
    </div>
    <ul class="card-grid">
      {posts.map((p) => (
        <li style="list-style:none">
          <ArticleCard post={p} showExcerpt={false} />
        </li>
      ))}
    </ul>
  </section>
)}
