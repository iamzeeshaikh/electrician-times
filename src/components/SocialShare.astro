---
import { absoluteUrl } from '../utils/site';

export interface Props {
  title: string;
  path: string;
}
const { title, path } = Astro.props;
const url = encodeURIComponent(absoluteUrl(path));
const text = encodeURIComponent(title);
---

<div class="share-row">
  <span>Share:</span>
  <a href={`https://www.facebook.com/sharer/sharer.php?u=${url}`} target="_blank" rel="noopener noreferrer">Facebook</a>
  <a href={`https://x.com/intent/post?url=${url}&text=${text}`} target="_blank" rel="noopener noreferrer">X</a>
  <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${url}`} target="_blank" rel="noopener noreferrer">LinkedIn</a>
  <a href={`mailto:?subject=${text}&body=${url}`}>Email</a>
</div>
